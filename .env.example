# Azure Resource Names
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-mediaops-dev
AZURE_LOCATION=eastus

# Storage
STORAGE_ACCOUNT_NAME=
STORAGE_CONNECTION_STRING=

# Cosmos DB
COSMOS_ENDPOINT=
COSMOS_PRIMARY_KEY=
COSMOS_DATABASE=mediaops
COSMOS_CONTAINER=MediaItems

# Key Vault
KEY_VAULT_NAME=
KEY_VAULT_URI=

# Entra ID / Auth
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# Container Registry (GHCR)
GHCR_IMAGE=ghcr.io/<your-github-username>/mediaops-worker:latest
